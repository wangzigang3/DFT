SYSTEM = vasp-static

# Accuracy
PREC   = Accurate
ENCUT  = 520
EDIFF  = 1E-6
LASPH  = .TRUE.
LREAL  = .FALSE.

# Electronic optimization
ALGO   = Normal
NELM   = 160
ISMEAR = 0
SIGMA  = 0.05
ISPIN  = 2

# Static calculation
IBRION = -1
NSW    = 0
ISIF   = 2

# Output control
LORBIT = 11
LWAVE  = .FALSE.
LCHARG = .TRUE.

# Parallel settings; tune for your cluster
NCORE  = 4
